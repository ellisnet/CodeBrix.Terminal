<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RemoteTerminal.Client.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RemoteTerminal.Client.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:RemoteTerminal.Client.ViewModels"
    xmlns:controls="using:RemoteTerminal.Client.Controls"
    mc:Ignorable="d"
    Title="Remote Terminal">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootUiElement" Margin="30">
        <Grid.DataContext>
            <vm:MainViewModel />
        </Grid.DataContext>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>
    
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Button Grid.Column="2" Grid.Row="0" Grid.ColumnSpan="2"
                HorizontalAlignment="Right" Margin="5"
                Command="{Binding ConnectToServerCommand}" 
                Content="{Binding ConnectToServerButtonText}" />

        <controls:TerminalControl x:Name="TerminalOutput"
                                   Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="4"
                                   Margin="2" />

        <TextBlock Grid.Column="0" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5">Input</TextBlock>

        <TextBox Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2"
                 VerticalAlignment="Center" Margin="5"
                 AcceptsReturn="True"
                 Text="{Binding InputToSend, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 IsReadOnly="{Binding IsNotReadyToSend}"></TextBox>

        <Button Grid.Column="3" Grid.Row="2"
                HorizontalAlignment="Left" Margin="5"
                Command="{Binding SendInputToRemoteCommand}">Send</Button>

    </Grid>
</Window>
